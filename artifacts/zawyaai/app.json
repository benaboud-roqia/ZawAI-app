{
  "expo": {
    "name": "ZawIA",
    "slug": "zawia",
    "version": "1.0.0",
    "owner": "zawia-organization",
    "extra": {
      "eas": {
        "projectId": "cf6d65c4-4821-47e8-a3f1-13cbb1535217"
      }
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zawyaai",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0F"
    },
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zawyaai.app"
    },
    "android": {
      "package": "com.zawyaai.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "ZawyaAI utilise la caméra pour la composition cinématographique en direct.",
          "microphonePermission": "ZawyaAI utilise le micro pour l'assistant vocal et la vidéo.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-router"
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
